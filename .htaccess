# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/esabaqco/demo.esabaq.com"
PassengerBaseURI "/"
PassengerPython "/home/esabaqco/virtualenv/demo.esabaq.com/3.11/bin/python"
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

# تمام ٹریفک Uvicorn (port 8001) کو بھیجیں
# X-Forwarded headers سے Uvicorn کو اصل domain پتہ چلے گا
<IfModule mod_headers.c>
    RequestHeader set X-Forwarded-Proto "https"
    RequestHeader set X-Forwarded-Host "demo.esabaq.com"
</IfModule>
<IfModule Litespeed>
    RequestHeader set X-Forwarded-Proto "https"
    RequestHeader set X-Forwarded-Host "demo.esabaq.com"
</IfModule>

RewriteEngine On
RewriteRule ^(.*)$ http://127.0.0.1:8001/$1 [P,L]

# DO NOT REMOVE OR MODIFY. CLOUDLINUX ENV VARS CONFIGURATION BEGIN
<IfModule Litespeed>
</IfModule>
# DO NOT REMOVE OR MODIFY. CLOUDLINUX ENV VARS CONFIGURATION END
